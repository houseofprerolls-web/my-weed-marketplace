{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');try{fs.rmSync('.next',{recursive:true,force:true})}catch(e){if(e.code!=='ENOENT')throw e;}\"",
    "tailwind:emit": "tailwindcss -i ./app/globals.css -o ./public/tailwind-app.css",
    "dev:prep": "npm run tailwind:emit && (node scripts/verify-homepage-banner-assets.mjs || node scripts/write-homepage-banner-placeholders.mjs)",
    "predev": "npm run dev:prep",
    "dev": "next dev -p 3000",
    "dev:fresh": "node scripts/free-dev-port.mjs 3000 && npm run clean && npm run dev:prep && next dev -p 3000",
    "dev:host": "npm run dev:prep && next dev -H 0.0.0.0 -p 3000",
    "dev:turbo": "npm run dev:prep && next dev --turbo -p 3000",
    "dev:clean": "npm run clean && npm run dev:prep && next dev -p 3000",
    "prebuild": "node scripts/write-homepage-banner-placeholders.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "seed:strains": "node scripts/seed-leafly-strains.cjs",
    "generate:uls-storefront": "node scripts/generate-uls-storefront-seed.cjs",
    "sync:uls-licenses": "node scripts/sync-business-licenses-from-uls-csv.cjs",
    "import:smokers-club-csv": "node scripts/import-smokers-club-csv.mjs",
    "import:findweedny-csv": "node scripts/import-findweedny-csv.mjs",
    "import:catalog-csv": "node scripts/import-catalog-csv.mjs",
    "generate:super-fresh-leafly-products-sql": "node scripts/generate-leafly-super-fresh-sql.mjs",
    "import:super-fresh-leafly": "node scripts/import-catalog-csv.mjs ./scripts/fixtures/super-fresh-farms-leafly-menu.csv --leafly --vendor-slug=super-fresh-farms --replace-vendor-menu",
    "import:super-fresh-leafly:dry": "node scripts/import-catalog-csv.mjs ./scripts/fixtures/super-fresh-farms-leafly-menu.csv --leafly --vendor-slug=super-fresh-farms --dry-run",
    "images:slots": "node scripts/download-site-slots-to-png.mjs",
    "downscale:mirrored-images": "node scripts/downscale-mirrored-images-in-bucket.mjs",
    "cleanup:mirrored-images:orphans": "node scripts/cleanup-unreferenced-mirrored-images.mjs",
    "refill:smokers-club-menus": "node scripts/refill-smokers-club-menus.mjs",
    "mirror:encyclopedia": "node scripts/mirror-encyclopedia-assets.mjs",
    "mirror:brands-strains": "node scripts/mirror-encyclopedia-assets.mjs --brands-and-strains-only",
    "verify:supabase": "node scripts/verify-supabase-keys.mjs",
    "outreach:replace-csv": "npx --yes tsx scripts/outreach-replace-from-csv.ts",
    "banners:write-placeholders": "node scripts/write-homepage-banner-placeholders.mjs",
    "verify:banner-assets": "node scripts/verify-homepage-banner-assets.mjs",
    "verify:marketing-banners": "node scripts/verify-marketing-banner-api.mjs",
    "audit:vendor-licenses": "node scripts/audit-directory-vendors-licenses.cjs",
    "fetch:vendor-logos": "node scripts/fetch-vendor-logos.mjs",
    "apply:weedmaps-csv-logos": "node scripts/apply-weedmaps-csv-logos.mjs",
    "fill:smokers-club-tree-logo": "node scripts/fill-smokers-club-tree-by-logo.mjs",
    "banners:smokers-club-strip": "node scripts/build-smokers-club-strip-banners.mjs",
    "vercel:deploy": "npx vercel@latest",
    "vercel:prod": "npx vercel@latest --prod"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@netlify/plugin-nextjs": "^5.15.1",
    "@next/swc-wasm-nodejs": "13.5.1",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",

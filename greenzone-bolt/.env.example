NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Vercel / production (shops, Discover, Map): add ALL of these in Vercel → Settings → Environment Variables, then redeploy ---
# DNS (e.g. GoDaddy): add both datreehouse.com and www.datreehouse.com in Vercel → Domains (primary: www). Point DNS records to Vercel per their wizard; remove parking/forwarding so traffic hits the app (not a registrar placeholder page).
# SEO go-live: set NEXT_PUBLIC_SITE_URL=https://www.datreehouse.com and NEXT_PUBLIC_ALLOW_INDEXING=1 on Production, then redeploy. Google Search Console: add the www property and submit https://www.datreehouse.com/sitemap.xml
# NEXT_PUBLIC_SUPABASE_URL=          (same as local)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=     (anon public key from Supabase → Settings → API)
# SUPABASE_SERVICE_ROLE_KEY=         (service_role secret — required for many server routes; without it you often see “missing … SERVICE_ROLE_KEY” and shops won’t load)
#
# Supabase Auth emails (sign-up confirmation, password reset, magic link): set in the Supabase Dashboard,
# not in this file — Authentication → SMTP Settings. Use your real SMTP (e.g. Microsoft 365 for connect@datreehouse.com)
# and set the sender to: Datreehouse <connect@datreehouse.com> (or your verified mailbox).
#
# Optional: match outreach “from” to Auth without duplicating OUTREACH_EMAIL_FROM — same verified address as Dashboard:
# RESEND_DEFAULT_FROM="connect@datreehouse.com"
# AUTH_EMAIL_FROM="connect@datreehouse.com"
# NEXT_PUBLIC_SITE_URL=https://www.datreehouse.com
# Optional: only if you need a fixed confirmation-link redirect (must match Supabase → Authentication → Redirect URLs exactly).
# If unset, sign-up uses Supabase project Site URL for email links (recommended).
# NEXT_PUBLIC_SUPABASE_AUTH_REDIRECT_URL=https://www.datreehouse.com
# NEXT_PUBLIC_USE_VENDORS_TABLE=1
# USE_VENDORS_TABLE=1
# NEXT_PUBLIC_MAPBOX_TOKEN=          (map pages)

# Canonical site URL for sitemap, robots, Open Graph resolution (no trailing slash). Production: https://www.datreehouse.com
NEXT_PUBLIC_SITE_URL=https://www.datreehouse.com

# For `npm run seed:strains` / `npm run import:catalog-csv` (never commit the service role).
# Local: uncomment. Vercel: set in dashboard (see block above) — do not use NEXT_PUBLIC_ for this key.
# SUPABASE_SERVICE_ROLE_KEY=
# Or use Postgres URI instead (Dashboard → Database → Connection string):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@...pooler.supabase.com:6543/postgres

# Mapbox GL (public token) — https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Soft launch (optional): comma-separated `vendors.slug` values visible on map, Discover, dispensaries, deals,
# Smokers Club tree, and live-menu counts. Leave unset to show all live approved vendors.
# Example: greenhaven,house-of-prerolls,ca-uls-c9-0000568-lic
# NEXT_PUBLIC_LAUNCH_VENDOR_SLUGS=

# CannaHub / this repo: use `public.vendors` (not `vendor_profiles`). Restart `next dev` after changing.
NEXT_PUBLIC_USE_VENDORS_TABLE=1
# Server/API routes (e.g. /api/discovery/vendors) — set on hosting even if you only rebuild client rarely.
USE_VENDORS_TABLE=1

# Blaze catalog sync (optional): override HTTP paths — defaults /api/v1/partner/store and /api/v1/partner/store/inventory/products (singular inventory; `/partner/` is Blaze’s URL prefix).
# Vendors save Developer Keys Secret on Menu → Sources; Key under Advanced when required (x-api-key + Authorization). See https://apidocs.blaze.me/getting-started/authentication
# BLAZE_DISABLE_CREDENTIAL_LENGTH_FIX=1  (optional; only if Key is longer than Secret and auto column swap is wrong)
# BLAZE_RETAILER_STORE_PATH=/api/v1/partner/store
# BLAZE_RETAILER_PRODUCTS_PATH=/api/v1/partner/store/inventory/products

# Supabase Storage image transforms (`/render/image`) — off by default; set to 1 only if enabled in Dashboard
# and you want smaller images. Wrong decoding shows as grey blobs while still loading successfully.
# NEXT_PUBLIC_SUPABASE_IMAGE_TRANSFORM=1

# Skip the 21+ full-screen gate in development (optional).
# NEXT_PUBLIC_SKIP_AGE_GATE=1

# Marketing carousel: use bundled `public/marketing-ad-demos/*.png` on every placement (different shuffle per slot).
# In `next dev` this defaults ON; set to 0 to load only Supabase slides. Production: omit or 0 unless you want demo art live.
# NEXT_PUBLIC_MARKETING_AD_DEMO=1
# NEXT_PUBLIC_MARKETING_AD_DEMO=0

# Octoparse (optional) — easier: use scripts/octoparse.env (see scripts/octoparse.env.example).
# OCTOPARSE_ACCESS_TOKEN=
# OCTOPARSE_SIZE=100

# Master-admin “outreach” (/admin/outreach): your mailbox’s SMTP (e.g. Outlook / Microsoft 365) or Resend
#
# --- Option A: SMTP — Microsoft 365 / Outlook (typical: STARTTLS on 587) ---
# If the account uses MFA, create an App Password in Microsoft account security settings for OUTREACH_SMTP_PASS.
# OUTREACH_SMTP_HOST=smtp.office365.com
# OUTREACH_SMTP_PORT=587
# OUTREACH_SMTP_SECURE=false
# OUTREACH_SMTP_USER=you@yourdomain.com
# OUTREACH_SMTP_PASS=
#
# Other hosts (e.g. implicit TLS on 465): set host/port and OUTREACH_SMTP_SECURE=true as required by the provider.
#
# --- Option B: Resend (same API key as Vercel / app: RESEND_API_KEY; or OUTREACH_RESEND_API_KEY) ---
# RESEND_API_KEY=                    (recommended — outreach uses this when set; no separate outreach key needed)
# OUTREACH_RESEND_API_KEY=           (optional override instead of RESEND_API_KEY)
#
# From identity: if unset but RESEND_API_KEY is set, outreach defaults to connect@datreehouse.com (same as Auth in the block above).
# Override default with OUTREACH_EMAIL_FROM or RESEND_DEFAULT_FROM / AUTH_EMAIL_FROM.
# OUTREACH_EMAIL_FROM="connect@datreehouse.com"
# Multiple verified senders (JSON allowlist). UI sends from_id; server validates against this list only.
# Example: [{"id":"onboarding","from":"Team <onboarding@domain.com>"},{"id":"sales","from":"Sales <sales@domain.com>"}]
# OUTREACH_EMAIL_FROM_OPTIONS=
# OUTREACH_EMAIL_HTML=               (optional custom HTML; merge {{person_name}} {{company_name}} {{unsubscribe_url}} {{phone}} {{uls_premise_kind}})
# OUTREACH_EMAIL_TEXT=               (optional custom plain text; same placeholders)
# OUTREACH_REPLY_TO=                 (optional)
# OUTREACH_EMAIL_SUBJECT=            (optional override)
# OUTREACH_EMAIL_TRANSPORT=          (optional: resend | smtp — default auto prefers Resend HTTP when RESEND_API_KEY is set)
# OUTREACH_UNSUBSCRIBE_SECRET=       (32+ chars; signed unsubscribe links)
# OUTREACH_INBOUND_WEBHOOK_SECRET=   (header x-outreach-webhook-secret on POST /api/master/outreach/inbound)
